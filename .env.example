# Anthropic (required if you use the Python HoldAgent class directly)
ANTHROPIC_API_KEY=

# SQLite DB (default: ./data/rookiecard.db)
DB_PATH=

# Logging
LOG_LEVEL=INFO

# eBay scraping
EBAY_DELAY=3.0
EBAY_TIMEOUT=20.0
EBAY_MAX_PAGES=3
EBAY_MAX_RETRIES=4
EBAY_HOLDINGS_DAYS=14
EBAY_HOLDINGS_MAX_PAGES=1
EBAY_USE_PLAYWRIGHT_FALLBACK=true
# EBAY_PROXY_URL=
# EBAY_PLAYWRIGHT_PROXY_URL=
